{
  "manifest_version": 3,
  "name": "Rior Systems Profit Intelligence",
  "version": "1.0.0",
  "description": "Real-time profit tracking and alerts for Shopify stores",
  "permissions": [
    "storage",
    "notifications",
    "alarms",
    "identity",
    "activeTab"
  ],
  "host_permissions": [
    "https://*.myshopify.com/admin/*",
    "https://api.rior.systems/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_badge_background_color": "#FF4444"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://*.myshopify.com/admin/orders*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    },
    {
      "matches": ["https://*.myshopify.com/admin/products/*"],
      "js": ["content-product.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "oauth2": {
    "client_id": "YOUR_CLIENT_ID",
    "scopes": ["openid", "email", "profile"]
  }
}