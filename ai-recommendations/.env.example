# Google Cloud Configuration
GCP_PROJECT_ID=rior-systems
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Discord Webhook (optional)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Looker Studio GCS Bucket (optional)
LOOKER_STUDIO_BUCKET=rior-looker-data

# Default Parameters
DEFAULT_BREAK_EVEN_ROAS=2.5
DEFAULT_DAYS_ANALYZED=30
